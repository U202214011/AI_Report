{
  "id": "cn_professional_report",
  "name": "内置模板2",
  "description": "黑色黑体",
  "page": {
    "size": "A4",
    "orientation": "portrait",
    "margin_cm": [
      2.8,
      2.4,
      2.6,
      2.4
    ]
  },
  "fonts": {
    "title": {
      "family": "微软雅黑",
      "size_pt": 20,
      "bold": true,
      "italic": false,
      "color": "#000029"
    },
    "h1": {
      "family": "微软雅黑",
      "size_pt": 18,
      "bold": true,
      "italic": false,
      "color": "#000000"
    },
    "h2": {
      "family": "微软雅黑",
      "size_pt": 16,
      "bold": true,
      "italic": false,
      "color": "#000000"
    },
    "h3": {
      "family": "微软雅黑",
      "size_pt": 12,
      "bold": true,
      "italic": false,
      "color": "#000000"
    },
    "h4": {
      "family": "微软雅黑",
      "size_pt": 11,
      "bold": true,
      "italic": false,
      "color": "#000000"
    },
    "body": {
      "family": "楷体",
      "size_pt": 12,
      "bold": false,
      "italic": false,
      "color": "#000000"
    },
    "list": {
      "family": "楷体",
      "size_pt": 12,
      "bold": false,
      "italic": false,
      "color": "#000000"
    }
  },
  "paragraph_styles": {
    "title": {
      "alignment": "center",
      "line_spacing": 2,
      "space_before_pt": 10,
      "space_after_pt": 10,
      "first_line_indent_chars": 0,
      "keep_with_next": true
    },
    "h1": {
      "alignment": "left",
      "line_spacing": 1.5,
      "space_before_pt": 18,
      "space_after_pt": 8,
      "first_line_indent_chars": 0,
      "keep_with_next": true
    },
    "h2": {
      "alignment": "left",
      "line_spacing": 1.5,
      "space_before_pt": 12,
      "space_after_pt": 6,
      "first_line_indent_chars": 2,
      "keep_with_next": true
    },
    "h3": {
      "alignment": "left",
      "line_spacing": 1.2,
      "space_before_pt": 8,
      "space_after_pt": 4,
      "first_line_indent_chars": 0,
      "keep_with_next": false
    },
    "h4": {
      "alignment": "left",
      "line_spacing": 1.2,
      "space_before_pt": 6,
      "space_after_pt": 2,
      "first_line_indent_chars": 0,
      "keep_with_next": false
    },
    "body": {
      "alignment": "justify",
      "line_spacing": 1.2,
      "space_before_pt": 0,
      "space_after_pt": 6,
      "first_line_indent_chars": 4
    },
    "list": {
      "alignment": "left",
      "line_spacing": 1.3,
      "space_before_pt": 0,
      "space_after_pt": 4,
      "first_line_indent_chars": 0
    }
  },
  "header_footer": {
    "header": {
      "text": "AI报告自动生成系统",
      "alignment": "center"
    },
    "footer": {
      "show_page_number": true,
      "prefix": "第 ",
      "suffix": " 页",
      "show_total_pages": true,
      "alignment": "center"
    }
  },
  "image": {
    "max_width_cm": 16,
    "alignment": "center"
  },
  "paragraph": {
    "line_spacing": 1.2,
    "space_before_pt": 4,
    "space_after_pt": 6,
    "first_line_indent_chars": 4
  }
}