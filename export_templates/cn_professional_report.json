{
  "id": "cn_professional_report",
  "name": "模板3",
  "description": "A4+页眉页脚",
  "page": {
    "size": "A4",
    "orientation": "portrait",
    "margin_cm": [2.8, 2.4, 2.6, 2.4],
    "header_distance_cm": 1.2,
    "footer_distance_cm": 1.2,
    "mirror_margins": false,
    "gutter_cm": 0
  },
  "header_footer": {
    "header": {
      "text": "AI报告自动生成系统",
      "alignment": "center"
    },
    "footer": {
      "show_page_number": true,
      "show_total_pages": true,
      "prefix": "第 ",
      "suffix": " 页",
      "alignment": "center"
    }
  },
  "fonts": {
    "title": { "family": "微软雅黑", "size_pt": 20, "bold": true },
    "h1":    { "family": "微软雅黑", "size_pt": 16, "bold": true },
    "h2":    { "family": "微软雅黑", "size_pt": 14, "bold": true },
    "h3":    { "family": "微软雅黑", "size_pt": 12, "bold": true },
    "h4":    { "family": "微软雅黑", "size_pt": 11, "bold": true },
    "body":  { "family": "宋体", "size_pt": 11, "bold": false },
    "list":  { "family": "宋体", "size_pt": 11, "bold": false },
    "code":  { "family": "Consolas", "size_pt": 10.5, "bold": false },
    "caption": { "family": "宋体", "size_pt": 10.5, "bold": false }
  },
  "paragraph_styles": {
    "title": {
      "alignment": "center",
      "line_spacing": 1.2,
      "space_before_pt": 0,
      "space_after_pt": 20,
      "first_line_indent_chars": 0,
      "keep_with_next": true
    },
    "h1": {
      "alignment": "left",
      "line_spacing": 1.2,
      "space_before_pt": 18,
      "space_after_pt": 8,
      "first_line_indent_chars": 0,
      "keep_with_next": true,
      "page_break_before": false
    },
    "h2": {
      "alignment": "left",
      "line_spacing": 1.2,
      "space_before_pt": 12,
      "space_after_pt": 6,
      "first_line_indent_chars": 0,
      "keep_with_next": true
    },
    "h3": {
      "alignment": "left",
      "line_spacing": 1.2,
      "space_before_pt": 8,
      "space_after_pt": 4,
      "first_line_indent_chars": 0,
      "keep_with_next": true
    },
    "body": {
      "alignment": "justify",
      "line_spacing": 1.5,
      "space_before_pt": 0,
      "space_after_pt": 6,
      "first_line_indent_chars": 2,
      "widow_control": true
    },
    "list": {
      "alignment": "left",
      "line_spacing": 1.3,
      "space_before_pt": 0,
      "space_after_pt": 4,
      "first_line_indent_chars": 0,
      "left_indent_cm": 0.63
    },
    "code": {
      "alignment": "left",
      "line_spacing": { "type": "exactly", "value": 15 },
      "space_before_pt": 0,
      "space_after_pt": 0,
      "first_line_indent_chars": 0,
      "left_indent_cm": 0.6,
      "right_indent_cm": 0.6
    },
    "caption": {
      "alignment": "center",
      "line_spacing": 1.0,
      "space_before_pt": 3,
      "space_after_pt": 8,
      "first_line_indent_chars": 0
    }
  },
  "table": {
    "style": "Table Grid",
    "header_font": { "family": "微软雅黑", "size_pt": 10.5, "bold": true }
  },
  "image": {
    "max_width_cm": 16,
    "alignment": "center",
    "caption_style": "caption",
    "paragraph": {
      "alignment": "center",
      "line_spacing": 1.0,
      "space_before_pt": 6,
      "space_after_pt": 3,
      "first_line_indent_chars": 0,
      "keep_with_next": true
    }
  },
  "paragraph": {
    "line_spacing": 1.5,
    "space_before_pt": 4,
    "space_after_pt": 6,
    "first_line_indent_chars": 2
  }
}